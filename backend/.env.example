OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
# Set to true when the API runs behind a reverse proxy (uses X-Forwarded-For for rate limits).
# TRUST_PROXY=true
# Optional: use this when your network uses a custom corporate/local CA certificate.
# NODE_EXTRA_CA_CERTS=/absolute/path/to/company-or-local-ca.pem
# NOTE: Use this only for development purpose
# NODE_TLS_REJECT_UNAUTHORIZED=0
